generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]

  @@map("categories")
}

model Product {
  id          Int              @id @default(autoincrement())
  name        String
  description String?
  price       Int              // precio en colones
  categoryId  Int
  category    Category         @relation(fields: [categoryId], references: [id])
  imageUrl    String?
  active      Boolean          @default(true)
  orderItems  OrderItem[]
  inventory   ProductInventory[]

  @@map("products")
}

model Order {
  id             Int         @id @default(autoincrement())
  customerName   String
  phone          String
  address        String?
  deliveryType   DeliveryType
  paymentMethod  PaymentMethod
  status         OrderStatus  @default(NUEVO)
  total          Int
  createdAt      DateTime     @default(now())
  items          OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Int

  @@map("order_items")
}

model InventoryItem {
  id       Int              @id @default(autoincrement())
  name     String
  stock    Float
  unit     String           // kg, unidades, etc.
  products ProductInventory[]

  @@map("inventory_items")
}

model ProductInventory {
  productId       Int
  product         Product       @relation(fields: [productId], references: [id])
  inventoryItemId Int
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantityUsed    Float

  @@id([productId, inventoryItemId])
  @@map("product_inventory")
}

enum DeliveryType {
  PICKUP
  ENVIO
}

enum PaymentMethod {
  EFECTIVO
  SINPE
}

enum OrderStatus {
  NUEVO
  ACEPTADO
  PREPARANDO
  LISTO
  ENTREGADO
  CANCELADO
}
